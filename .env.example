DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/stock_delivery
DATABASE_CONNECT_TIMEOUT=10
DATABASE_POOL_RECYCLE_SECONDS=1800
# Set DATABASE_SSLMODE=require for hosted PostgreSQL providers that require TLS.
DATABASE_SSLMODE=
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_JSON=
AI_PROVIDER=deterministic
OPENAI_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Disable anonymous Next.js telemetry in local, Docker, Vercel, and CI builds.
NEXT_TELEMETRY_DISABLED=1
